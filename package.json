{
	"name": "@deskbtm/react-native-bottom-sheet",
	"version": "0.0.1",
	"description": "React Native bottom sheet with iOS presentation and custom push host modes, modal overlay, snap points, keyboard and scroll handoff",
	"keywords": [
		"BottomSheet",
		"bottom-sheet",
		"expo",
		"presentation",
		"push",
		"react-native"
	],
	"homepage": "https://github.com/deskbtm/react-native-bottom-sheet#readme",
	"bugs": {
		"url": "https://github.com/deskbtm/react-native-bottom-sheet/issues"
	},
	"license": "MIT",
	"author": "han9088 <wanghan9423@outlook.com> (https://github.com/nawbc)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/deskbtm/react-native-bottom-sheet.git"
	},
	"source": "src/index.ts",
	"files": [
		"build",
		"src",
		"!src/**/__tests__/**",
		"android/build.gradle",
		"android/src",
		"ios",
		"expo-module.config.json"
	],
	"main": "build/index.js",
	"types": "build/index.d.ts",
	"react-native": "src/index.ts",
	"exports": {
		".": {
			"types": "./build/index.d.ts",
			"react-native": "./src/index.ts",
			"default": "./build/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "node internal/module_scripts/build.js",
		"build:ci": "node internal/module_scripts/build.js",
		"prepack": "node internal/module_scripts/prepare.js --force",
		"prepublishOnly": "node internal/module_scripts/build.js",
		"clean": "node internal/module_scripts/clean.js",
		"lint": "oxlint -c oxlint.config.ts .",
		"fmt": "oxfmt --write . && oxfmt --write '**/*.{json,jsonc}'",
		"fmt:check": "oxfmt --check . && oxfmt --check '**/*.{json,jsonc}'",
		"test": "node internal/module_scripts/test.js",
		"test:ci": "jest --watchAll=false --ci",
		"validate": "pnpm run fmt:check && pnpm run lint && pnpm run test:ci && pnpm run build:ci",
		"validate:example": "pnpm --filter bottom-sheet-example run validate",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm validate && changeset publish",
		"prepare": "node internal/module_scripts/prepare.js",
		"open:ios": "node internal/module_scripts/open-ios.js",
		"open:android": "node internal/module_scripts/open-android.js",
		"example": "pnpm --filter bottom-sheet-example start"
	},
	"devDependencies": {
		"@babel/core": "^7.26.0",
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.31.0",
		"@react-native/jest-preset": "0.86.0",
		"@react-native/metro-config": "0.86.0",
		"@testing-library/react-native": "^14.0.0",
		"@types/jest": "^29.2.1",
		"@types/node": "^22.10.0",
		"@types/react": "~19.2.2",
		"babel-preset-expo": "~57.0.1",
		"expo": "~57.0.2",
		"jest": "^29.7.0",
		"jest-expo": "~57.0.1",
		"oxfmt": "0.58.0",
		"oxlint": "1.73.0",
		"oxlint-tsgolint": "0.24.0",
		"react": "19.2.3",
		"react-native": "0.86.0",
		"react-native-gesture-handler": "2.32.0",
		"react-native-keyboard-controller": "^1.21.9",
		"react-native-reanimated": "4.5.0",
		"react-native-safe-area-context": "5.7.0",
		"react-native-worklets": "0.10.0",
		"typescript": "~6.0.3"
	},
	"peerDependencies": {
		"expo": "*",
		"react": "*",
		"react-native": "*",
		"react-native-gesture-handler": ">=2.0.0",
		"react-native-keyboard-controller": ">=1.0.0",
		"react-native-reanimated": ">=4.0.0",
		"react-native-safe-area-context": ">=5.0.0",
		"react-native-worklets": ">=0.8.0"
	},
	"jest": {
		"preset": "jest-expo",
		"roots": [
			"<rootDir>/src"
		],
		"setupFilesAfterEnv": [
			"<rootDir>/tests/jest.setup.ts"
		],
		"testMatch": [
			"<rootDir>/src/**/__tests__/**/*.test.[jt]s?(x)"
		]
	},
	"packageManager": "pnpm@9.15.9"
}
