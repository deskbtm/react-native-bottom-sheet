{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"],
      "@deskbtm-rn/bottom-sheet": ["../src/index"],
      "@deskbtm-rn/bottom-sheet/*": ["../src/*"],
      "bottom-sheet": ["../src/index"],
      "bottom-sheet/*": ["../src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
