{
	"name": "bottom-sheet-example",
	"version": "1.0.0",
	"private": true,
	"main": "index.ts",
	"scripts": {
		"start": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"typecheck": "tsc --noEmit",
		"export:web": "expo export --platform web",
		"prebuild:android": "expo prebuild --platform android --no-install",
		"build:android": "expo prebuild --platform android --no-install && node scripts/configure-android-release-signing.js && cd android && ./gradlew assembleRelease --no-daemon",
		"validate": "pnpm run typecheck && pnpm run build:android"
	},
	"dependencies": {
		"@deskbtm/react-native-bottom-sheet": "workspace:*",
		"@expo/dom-webview": "~57.0.0",
		"@expo/metro-runtime": "57.0.3",
		"@react-navigation/bottom-tabs": "7.16.2",
		"@react-navigation/elements": "2.9.19",
		"@react-navigation/native": "7.2.5",
		"@react-navigation/native-stack": "7.16.0",
		"expo": "57.0.2",
		"expo-asset": "57.0.3",
		"expo-build-properties": "~57.0.0",
		"expo-constants": "57.0.3",
		"expo-dev-client": "57.0.5",
		"expo-linking": "57.0.1",
		"expo-splash-screen": "57.0.2",
		"expo-status-bar": "57.0.0",
		"expo-system-ui": "57.0.0",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-native": "0.86.0",
		"react-native-gesture-handler": "2.32.0",
		"react-native-keyboard-controller": "^1.21.9",
		"react-native-reanimated": "4.5.0",
		"react-native-safe-area-context": "5.7.0",
		"react-native-screens": "4.25.2",
		"react-native-web": "0.21.2",
		"react-native-worklets": "0.10.0"
	},
	"devDependencies": {
		"@babel/preset-typescript": "^7.29.7",
		"@types/react": "~19.2.2",
		"babel-preset-expo": "~57.0.1",
		"typescript": "~6.0.3"
	},
	"expo": {
		"autolinking": {
			"nativeModulesDir": ".."
		}
	}
}
